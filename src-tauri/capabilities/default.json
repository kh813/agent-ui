{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "store:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "agy", "cmd": "agy" },
        { "name": "bash", "cmd": "bash", "args": [ { "validator": ".*" } ] },
        { "name": "powershell", "cmd": "powershell.exe", "args": [ { "validator": ".*" } ] }
      ]
    }
  ]
}
