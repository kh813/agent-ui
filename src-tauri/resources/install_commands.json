{
  "agy": {
    "name": "Antigravity CLI",
    "binary": "agy",
    "detect_paths": {
      "macos": [
        "/usr/local/bin/agy",
        "/opt/homebrew/bin/agy",
        "$HOME/.gemini/antigravity-cli/bin/agy"
      ],
      "windows": [
        "$USERPROFILE\\.gemini\\antigravity-cli\\bin\\agy.exe",
        "$USERPROFILE\\AppData\\Local\\antigravity-cli\\bin\\agy.exe"
      ]
    },
    "version_args": ["--version"],
    "install": {
      "macos": {
        "command": "bash",
        "args": ["-c", "mkdir -p bin && curl -fsSL https://antigravity.google.com/install.sh | BINDIR=./bin bash"]
      },
      "windows": {
        "command": "powershell.exe",
        "args": ["-Command", "if (!(Test-Path 'bin')) { New-Item -ItemType Directory 'bin' }; $env:BINDIR='.\\bin'; iex (iwr -useb https://antigravity.google.com/install.ps1)"]
      }
    },
    "update": {
      "macos": {
        "command": "agy",
        "args": ["self-update"]
      },
      "windows": {
        "command": "agy.exe",
        "args": ["self-update"]
      }
    }
  }
}
