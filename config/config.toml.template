# agent-ui configuration template
# Copy this file to config.toml (project root) and fill in your values.
# config.toml is gitignored but read at runtime.

[oauth]
# Google OAuth2 credentials (GCP Console -> APIs & Services -> Credentials)
client_id     = "YOUR_CLIENT_ID.apps.googleusercontent.com"
client_secret = "YOUR_CLIENT_SECRET"

[drive]
# Google Drive -- Skill Catalog shared folder (used by the skill-catalog skill)
catalog_folder_id = "YOUR_CATALOG_FOLDER_ID"
catalog_url       = "https://drive.google.com/drive/folders/YOUR_CATALOG_FOLDER_ID"
catalog_file_id   = ""

[user]
# Your email address. If omitted, auto-detected from OS login name (requires
# a wrapping project to supply [company].domain — see below).
# email = "firstname.lastname@example.com"

[notifications]
# Google Chat incoming webhook URL, used to deliver results from headless/
# scheduled runs (e.g. a cron job invoking `agy --print`). Leave empty to
# disable — set up with the `notify-chat` skill, which guides you through
# creating a Chat space and issuing the webhook URL.
chat_webhook_url = ""

# [company] is intentionally not declared here. It's an optional overlay a
# wrapping project (e.g. an internal fork) can add to its own config.toml to
# enable company-domain email auto-detection and Salesforce link shortcuts:
#
# [company]
# domain = "example.com"
# portal_url = "https://sites.google.com/example.com/portal/home"
# salesforce_url = "https://your-org.my.salesforce.com/"
